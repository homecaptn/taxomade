---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Taxomade | Relocation & Tax Optimization">
  <div class="min-h-[80vh] flex flex-col items-center justify-center p-8 text-center">
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-gray-900 mb-6">
      Willkommen bei <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-600">Taxomade</span>
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
      Dein Partner für Digital Nomad Visas, Firmengründungen und Steuervorteile in Griechenland, Spanien, Italien und Bulgarien.
    </p>
    <a href="#apply" class="inline-flex items-center justify-center px-8 py-3.5 border border-transparent text-base font-medium rounded-full text-white bg-gray-900 hover:bg-gray-800 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5">
      Starte jetzt
    </a>
  </div>
</Layout>
