---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhatWeDo from '../components/WhatWeDo.astro';
import Timeline from '../components/Timeline.astro';
import GeneralProcess from '../components/GeneralProcess.astro';
import Configurator from '../components/Configurator.astro';
import Simplicity from '../components/Simplicity.astro';

import Trust from '../components/Trust.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import AboutUs from '../components/AboutUs.astro';
import Prices from '../components/Prices.astro';
---
<Layout title="taxomade | Relocate to Greece">
  <main class="min-h-screen">
    <Hero />
    <WhatWeDo />
    <GeneralProcess />
    <Timeline />
    <AboutUs />
    <Configurator />
    <Simplicity />

    <Prices />
    <Trust />
    <Contact />
    
    <section class="py-12 bg-white text-center border-t border-slate-100">
      <p class="text-slate-600 mb-4">Looking to move somewhere else?</p>
      <a href="#contact" class="inline-flex items-center text-blue-800 font-medium hover:underline">
        Interest in Spain, Italy, or Bulgaria? Let us know &rarr;
      </a>
    </section>
  </main>
  <Footer />
</Layout>
