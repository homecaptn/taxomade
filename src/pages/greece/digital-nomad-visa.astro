---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Digital Nomad Visa Greece | Taxomade">
  <!-- Section 1: Hero (Conversion Optimized) -->
  <div class="relative pt-32 pb-24 md:pt-40 md:pb-32 overflow-hidden bg-slate-50">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-white/80 via-white/50 to-slate-50/20"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Copy & CTAs -->
        <div class="max-w-2xl">
          <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 tracking-tight leading-tight">
            We manage your whole visa application <span class="text-blue-800">—</span> end to end.
          </h1>
          <p class="text-xl text-slate-600 mb-8 leading-relaxed">
            Live legally in Greece while working remotely. Get your Digital Nomad Visa without the stress of Greek bureaucracy.
          </p>
          
          <!-- Benefit Checkmarks -->
          <ul class="space-y-3 mb-10">
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Fully managed, end-to-end process
            </li>
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Document prep & translations handled
            </li>
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Handled by licensed local experts
            </li>
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              All communication in plain English
            </li>
          </ul>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 mb-4">
            <a href="/#configurator" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl text-white bg-slate-900 hover:bg-blue-800 transition-colors duration-200 shadow-md">
              Get started
            </a>
            <a href="/#contact" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl text-slate-700 bg-white border-2 border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-colors duration-200">
              Talk to us
            </a>
          </div>
          <p class="text-sm text-slate-500 font-medium flex items-center">
            <svg class="w-4 h-4 text-slate-400 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd"></path></svg>
            Trusted by remote workers moving to Greece
          </p>
        </div>
        
        <!-- Right: Visual Mockup (Placeholder for now) -->
        <div class="hidden lg:block relative">
          <div class="absolute inset-0 bg-gradient-to-tr from-blue-100 to-emerald-50 rounded-3xl transform rotate-3 scale-105 opacity-50"></div>
          <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-8 relative overflow-hidden aspect-square flex flex-col justify-center items-center text-center">
            <div class="w-20 h-20 bg-blue-50 rounded-2xl flex items-center justify-center mb-6">
              <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-2">Visa Approved</h3>
            <p class="text-slate-500">Your transition to Greece, completely stress-free.</p>
            <div class="mt-8 w-full space-y-3">
              <div class="h-3 bg-slate-100 rounded-full w-3/4 mx-auto"></div>
              <div class="h-3 bg-slate-100 rounded-full w-1/2 mx-auto"></div>
              <div class="h-3 bg-slate-100 rounded-full w-5/6 mx-auto"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <main class="py-20 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <!-- Section 2: What it is & Requirements -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
      <!-- What it is Card -->
      <section class="bg-white p-8 md:p-10 rounded-3xl border border-slate-200 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50 rounded-bl-full -z-0"></div>
        <div class="relative z-10">
          <span class="inline-block px-3 py-1 mb-6 text-xs font-bold uppercase tracking-wider text-blue-800 bg-blue-100 rounded-full">For Whom</span>
          <h2 class="text-3xl font-bold text-slate-900 mb-4">What it is & why you need it</h2>
          <p class="text-lg text-slate-700 leading-relaxed">
            The Greece Digital Nomad Visa lets non-EU citizens live in Greece for up to 12 months (extendable to 2 years) while working remotely.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start text-slate-700">
              <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <strong>Live legally:</strong> Avoid 90-day Schengen limits.
            </li>
            <li class="flex items-start text-slate-700">
              <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <strong>Bring your family:</strong> Spouses and children can join you.
            </li>
            <li class="flex items-start text-slate-700">
              <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <strong>Keep your job:</strong> Work for your foreign employer or clients.
            </li>
          </ul>
        </div>
      </section>

      <!-- Requirements Card -->
      <section class="bg-slate-900 p-8 md:p-10 rounded-3xl shadow-sm text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-slate-800 rounded-bl-full -z-0"></div>
        <div class="relative z-10">
          <span class="inline-block px-3 py-1 mb-6 text-xs font-bold uppercase tracking-wider text-emerald-400 bg-emerald-400/10 rounded-full">Checklist</span>
          <h2 class="text-3xl font-bold mb-4">Requirements</h2>
          <p class="text-slate-300 mb-6">Do you qualify? Here is what you need:</p>
          <ul class="space-y-4 text-lg text-slate-200">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>Non-EU Citizen</strong> (EU citizens don't need a visa).</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>€3,500/mo net income</strong> from outside Greece (+20% for spouse, +15% per child).</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>Proof of remote work</strong> (contracts, invoices, payslips).</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span>Standard docs (passport, insurance, clean record).</span>
            </li>
          </ul>
        </div>
      </section>
    </div>

    <!-- How it works -->
    <section class="max-w-4xl mx-auto mb-20 bg-slate-50 p-8 md:p-12 rounded-3xl border border-slate-100">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-center">How it works</h2>
      
      <div class="mb-10 bg-blue-50 border-l-4 border-blue-800 p-5 rounded-r-lg">
        <p class="text-blue-900 font-medium"><em>Important 2026 change:</em> As of February 2026, you must apply at a <strong class="text-blue-900">Greek consulate in your home country before travelling</strong> — in-country applications are no longer possible.</p>
      </div>

      <div class="space-y-10">
        <div class="flex">
          <div class="flex-shrink-0 mr-6">
            <span class="w-12 h-12 rounded-full bg-slate-900 text-white flex items-center justify-center text-xl font-bold shadow-md">1</span>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-slate-900 mb-3">What you do</h3>
            <p class="text-lg text-slate-700">Gather your documents (we tell you exactly which), attend your consulate appointment, and travel to Greece once approved.</p>
          </div>
        </div>
        <div class="flex">
          <div class="flex-shrink-0 mr-6">
            <span class="w-12 h-12 rounded-full bg-blue-800 text-white flex items-center justify-center text-xl font-bold shadow-md">2</span>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-slate-900 mb-3">What Taxomade does</h3>
            <p class="text-lg text-slate-700">We review your situation, prepare and check your full document set, handle translations and legalizations, guide you through the consulate submission, and after arrival help you get your tax number (AFM) and residence permit. Processing typically takes around 1–3 months.</p>
          </div>
        </div>
      </div>
      <p class="text-slate-500 mt-10 text-sm italic text-center">Government fees (visa fee + €1,016 residence permit fee) are paid by you directly to the authorities and are separate from our service fee.</p>
    </section>

    <!-- Pricing Package -->
    <section class="max-w-md mx-auto mb-20">
      <div class="bg-white rounded-2xl shadow-xl border border-slate-200 overflow-hidden relative">
        <div class="p-8">
          <h3 class="text-2xl font-bold text-slate-900 mb-2">Digital Nomad Visa Package</h3>
          <p class="text-slate-500 mb-6">Full end-to-end management of your DNV application.</p>
          <div class="flex items-baseline mb-8">
            <span class="text-5xl font-black text-slate-900">€1.500</span>
            <span class="text-slate-500 ml-2">/ one-off</span>
          </div>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-blue-800 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Eligibility check & document review</li>
            <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-blue-800 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Document translation & legalization support</li>
            <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-blue-800 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Consulate appointment prep</li>
            <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-blue-800 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> AFM registration upon arrival</li>
          </ul>
          <a href="/#configurator" class="block w-full py-4 px-6 bg-slate-900 hover:bg-blue-800 text-white font-bold rounded-xl transition-colors duration-200 text-center">Start application</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-3xl mx-auto mb-20">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-10 text-center">FAQ</h2>
      <div class="space-y-6">
        <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Can freelancers apply?</h4>
          <p class="text-lg text-slate-700">Yes — as long as you can document ongoing clients and income from outside Greece.</p>
        </div>
        <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Can I work for a Greek company?</h4>
          <p class="text-lg text-slate-700">No. Your income must come from abroad.</p>
        </div>
        <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Can my family come?</h4>
          <p class="text-lg text-slate-700">Yes, with higher income proof (+20% spouse, +15% per child). They can live but not work locally.</p>
        </div>
        <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Does it lead to tax residency?</h4>
          <p class="text-lg text-slate-700">If you stay more than 183 days, yes — and then you may qualify for the 50% tax break (see Article 5C).</p>
        </div>
        <div class="bg-white p-6 rounded-xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">How long is it valid?</h4>
          <p class="text-lg text-slate-700">12 months initially, extendable to two years.</p>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>
