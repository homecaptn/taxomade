---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import AboutUsShort from '../../components/AboutUsShort.astro';
import ServiceContactForm from '../../components/ServiceContactForm.astro';
---

<Layout title="Ongoing Bookkeeping Greece | Taxomade">
  <!-- Section 1: Hero (Conversion Optimized) -->
  <div class="relative pt-32 pb-24 md:pt-40 md:pb-32 overflow-hidden bg-slate-50">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-white/80 via-white/50 to-slate-50/20"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Copy & CTAs -->
        <div class="max-w-2xl">
          <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 tracking-tight leading-tight">
            Your Greek bookkeeping, fully handled <span class="text-blue-800">—</span> in English.
          </h1>
          <p class="text-xl text-slate-600 mb-8 leading-relaxed">
            Stay compliant every month without touching Greek bureaucracy. We take care of your monthly reporting and annual tax returns.
          </p>
          
          <!-- Benefit Checkmarks -->
          <ul class="space-y-3 mb-10">
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Monthly compliance done for you
            </li>
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              E-invoicing 2026 ready
            </li>
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Handled by licensed Greek accountants
            </li>
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Simple monthly subscription
            </li>
          </ul>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 mb-4">
            <a href="/#configurator" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl text-white bg-slate-900 hover:bg-blue-800 transition-colors duration-200 shadow-md">
              Get started
            </a>
            <a href="/call" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl text-slate-700 bg-white border-2 border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-colors duration-200">
              Talk to us
            </a>
          </div>
          <p class="text-sm text-slate-500 font-medium flex items-center">
            <svg class="w-4 h-4 text-slate-400 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd"></path></svg>
            Trusted by remote workers moving to Greece
          </p>
        </div>
        
        <!-- Right: Visual Mockup -->
        <div class="hidden lg:flex justify-end relative">
          <div class="relative w-full max-w-md">
            <div class="absolute inset-0 bg-gradient-to-tr from-blue-100 to-emerald-50 rounded-3xl transform rotate-3 scale-105 text-slate-400"></div>
            <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-10 relative overflow-hidden flex flex-col justify-center items-center text-center">
              <div class="w-20 h-20 bg-blue-50 rounded-2xl flex items-center justify-center mb-6">
                <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-900 mb-2">myDATA Compliant</h3>
              <p class="text-slate-500">Your monthly reporting perfectly organized.</p>
              <div class="mt-8 w-full flex justify-between px-2">
                <div class="w-1/3 h-14 bg-slate-100 rounded-lg"></div>
                <div class="w-1/3 h-14 bg-slate-100 rounded-lg mx-3"></div>
                <div class="w-1/3 h-14 bg-blue-100 rounded-lg border border-blue-200"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <main class="py-20 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <!-- Section 2: Service Overview & Requirements -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
      <!-- What it is Card -->
      <section class="bg-white p-8 md:p-10 rounded-3xl border border-slate-200 shadow-sm relative overflow-hidden flex flex-col justify-center">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50 rounded-bl-full -z-0"></div>
        <div class="relative z-10">
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-blue-800 bg-blue-100 rounded-full">Freelancers</span>
            <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-blue-800 bg-blue-100 rounded-full">Remote Employees</span>
          </div>
          <h2 class="text-3xl font-bold text-slate-900 mb-4">The Essentials</h2>
          <p class="text-lg text-slate-700 leading-relaxed mb-6">
            Once you register as self-employed in Greece, you have strict ongoing obligations. We act as your licensed accountant to handle it all in plain English, so you stay compliant without the stress.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start text-slate-700">
              <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <strong>Freelancers:</strong> Full monthly bookkeeping & compliance.
            </li>
            <li class="flex items-start text-slate-700">
              <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <strong>Remote Employees:</strong> Typically only an annual tax return (we do this too).
            </li>
          </ul>
        </div>
      </section>

      <!-- Requirements Card -->
      <section class="bg-slate-900 p-8 md:p-10 rounded-3xl shadow-sm text-white relative overflow-hidden flex flex-col justify-center">
        <div class="absolute top-0 right-0 w-32 h-32 bg-slate-800 rounded-bl-full -z-0"></div>
        <div class="relative z-10">
          <span class="inline-block px-3 py-1 mb-6 text-xs font-bold uppercase tracking-wider text-emerald-400 bg-emerald-400/10 rounded-full">Checklist</span>
          <h2 class="text-3xl font-bold mb-4">Eligibility & Prerequisites</h2>
          <p class="text-slate-300 mb-6">Here is what we need to get started:</p>
          <ul class="space-y-4 text-lg text-slate-200">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>Freelancer registration:</strong> You must be registered in Greece (we handle this registration too).</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>An AFM (Tax ID):</strong> We can set this up for you if you don't have it.</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>Remote employees:</strong> If you stay 183+ days, you need an annual return.</span>
            </li>
          </ul>
        </div>
      </section>
    </div>

            <!-- Section 3: Split Timeline -->
    <section class="max-w-4xl mx-auto mb-24 px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">How it works, <span class="text-slate-400">how little you do.</span></h2>
        <p class="text-lg text-slate-600">You send your numbers, we do the rest.</p>
      </div>
      
      <div class="relative">
        <!-- Central Line -->
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-slate-200 -translate-x-1/2"></div>
        
        <!-- Step 1 -->
        <div class="relative flex flex-col md:flex-row items-center justify-between mb-16">
          <div class="md:w-[45%] mb-6 md:mb-0 md:text-right text-slate-500">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-xs font-bold uppercase tracking-wider mb-3">
              Your part
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Sign Authorization</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Say yes and sign the authorization.</p>
          </div>
          
          <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-white border-2 border-slate-300 text-slate-400 font-bold z-10 hidden md:flex">
            1
          </div>
          
          <div class="md:w-[45%] text-center md:text-left">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold uppercase tracking-wider mb-3">
              taxomade™
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">One-time setup</h3>
            <p class="text-slate-600 text-sm leading-relaxed">We register your freelancer status, EFKA, VAT and e-invoicing.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative flex flex-col md:flex-row items-center justify-between mb-16">
          <div class="md:w-[45%] mb-6 md:mb-0 md:text-right text-slate-500">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-xs font-bold uppercase tracking-wider mb-3">
              <span class="mr-2 text-slate-400">~5 min</span> Your part
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Send invoices</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Send us your invoices and income.</p>
          </div>
          
          <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-white border-2 border-slate-300 text-slate-400 font-bold z-10 hidden md:flex">
            2
          </div>
          
          <div class="md:w-[45%] text-center md:text-left">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold uppercase tracking-wider mb-3">
              taxomade™
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Each month</h3>
            <p class="text-slate-600 text-sm leading-relaxed">We file your myDATA, EFKA, VAT and issue compliant e-invoices.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative flex flex-col md:flex-row items-center justify-between">
          <div class="md:w-[45%] mb-6 md:mb-0 md:text-right text-slate-500">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-xs font-bold uppercase tracking-wider mb-3">
              Your part
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Nothing</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Nothing — we already have it.</p>
          </div>
          
          <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-emerald-600 text-white font-bold border-2 border-emerald-600 z-10 hidden md:flex shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          </div>
          
          <div class="md:w-[45%] text-center md:text-left">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-100 text-emerald-800 text-xs font-bold uppercase tracking-wider mb-3">
              taxomade™
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Year-end</h3>
            <p class="text-slate-600 text-sm leading-relaxed">We file your annual accounts and tax return, with a plain-English summary.</p>
          </div>
        </div>

      </div>
      
      <div class="mt-16 text-center">
        <p class="text-xl font-medium text-slate-700 mb-8 italic">"You send your numbers once a month. We handle everything else — in English."</p>
        <a href="#configurator" class="inline-flex items-center justify-center px-10 py-4 text-lg font-bold rounded-xl text-white bg-slate-900 hover:bg-blue-800 transition-colors duration-200 shadow-xl hover:-translate-y-1 transform mb-16">
          Start your bookkeeping
        </a>
      </div>

      <!-- Add-on Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto border-t border-slate-200 pt-16">
        <a href="#" class="bg-slate-50 rounded-2xl p-6 border border-slate-200 hover:border-blue-300 hover:bg-blue-50 transition-colors group block">
          <h4 class="font-bold text-slate-900 mb-2 group-hover:text-blue-700">Greek bank account help &rarr;</h4>
          <p class="text-sm text-slate-500">We assist you in opening a local business account remotely.</p>
        </a>
        <a href="#" class="bg-slate-50 rounded-2xl p-6 border border-slate-200 hover:border-blue-300 hover:bg-blue-50 transition-colors group block">
          <h4 class="font-bold text-slate-900 mb-2 group-hover:text-blue-700">Registered business address &rarr;</h4>
          <p class="text-sm text-slate-500">Don't have an office yet? Use our compliant local address.</p>
        </a>
        <a href="#" class="bg-slate-50 rounded-2xl p-6 border border-slate-200 hover:border-blue-300 hover:bg-blue-50 transition-colors group block">
          <h4 class="font-bold text-slate-900 mb-2 group-hover:text-blue-700">Health insurance &rarr;</h4>
          <p class="text-sm text-slate-500">Get recommendations for top expat-friendly providers.</p>
        </a>
      </div>
    </section>

    <!-- Pricing Package -->
    <section class="max-w-5xl mx-auto mb-24 px-4 sm:px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Single Service -->
        <div class="bg-white rounded-3xl shadow-xl border border-slate-200 overflow-hidden relative transform transition duration-300 hover:-translate-y-1 hover:shadow-2xl">
          <div class="absolute top-0 left-0 w-full h-1 bg-blue-800"></div>
          <div class="p-8 h-full flex flex-col">
            <h3 class="text-2xl font-bold text-slate-900 mb-2">Freelancer Accounting</h3>
            <p class="text-slate-500 mb-6 flex-grow">Complete monthly bookkeeping, tax, and social security compliance.</p>
            <div class="flex items-baseline mb-8">
              <span class="text-5xl font-black text-slate-900">€149</span>
              <span class="text-slate-500 ml-2">/ month</span>
            </div>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-emerald-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Monthly myDATA reporting & VAT returns</li>
              <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-emerald-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> EFKA (social security) management</li>
              <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-emerald-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Annual Greek tax return included</li>
              <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-emerald-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> E-invoicing setup & support</li>
            </ul>
            <a href="/#configurator" class="block w-full py-4 px-6 bg-slate-100 hover:bg-slate-200 text-slate-900 font-bold rounded-xl transition-colors duration-200 text-center">Start your bookkeeping</a>
          </div>
        </div>

        <!-- Full Package -->
        <div class="bg-slate-900 rounded-3xl shadow-2xl border border-slate-800 overflow-hidden relative transform transition duration-300 hover:-translate-y-1 hover:shadow-blue-900/50">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500 rounded-bl-full opacity-20 -z-0"></div>
          <div class="absolute top-0 left-0 w-full h-1 bg-emerald-400"></div>
          <div class="p-8 h-full flex flex-col relative z-10">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-400/20 text-emerald-400 text-xs font-bold uppercase tracking-wider mb-4 w-max">Most Popular</div>
            <h3 class="text-2xl font-bold text-white mb-2">The Complete Setup</h3>
            <p class="text-slate-400 mb-6 flex-grow">Everything you need to legally work and live in Greece.</p>
            <div class="flex items-baseline mb-8">
              <span class="text-5xl font-black text-white">Custom</span>
            </div>
            <ul class="space-y-4 mb-8 text-slate-300">
              <li class="flex items-start"><svg class="w-5 h-5 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> DNV & Residence Permit</li>
              <li class="flex items-start"><svg class="w-5 h-5 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> AFM Registration</li>
              <li class="flex items-start"><svg class="w-5 h-5 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Article 5C Application</li>
              <li class="flex items-start"><svg class="w-5 h-5 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Freelancer Setup & Bookkeeping</li>
            </ul>
            <a href="#configurator" class="block w-full py-4 px-6 bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-bold rounded-xl transition-colors duration-200 text-center shadow-lg">Build Your Package</a>
          </div>
        </div>
      </div>
    </section>

    <AboutUsShort />

    <!-- FAQ -->
    <section class="max-w-3xl mx-auto mb-24">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-10 text-center">FAQ</h2>
      <div class="space-y-6">
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Do I really need an accountant in Greece?</h4>
          <p class="text-lg text-slate-700">For freelancers, ongoing reporting (myDATA, EFKA, VAT) is effectively mandatory and in Greek — almost everyone uses an accountant.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">What about the new e-invoicing in 2026?</h4>
          <p class="text-lg text-slate-700">From October 2026, structured B2B e-invoicing via myDATA becomes mandatory. We set it up and manage it for you.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">I'm a remote employee, not a freelancer — what do I need?</h4>
          <p class="text-lg text-slate-700">Usually just an annual Greek tax return, which we handle — not the full monthly service.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">How much does it cost?</h4>
          <p class="text-lg text-slate-700">A simple monthly subscription; the exact price depends on your situation — request a quote.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Can you also handle my 5C tax break?</h4>
          <p class="text-lg text-slate-700">Yes — we combine it with your bookkeeping so everything's in one place.</p>
        </div>
      </div>
    </section>

    <ServiceContactForm />

  </main>
  
  <Footer />
</Layout>
