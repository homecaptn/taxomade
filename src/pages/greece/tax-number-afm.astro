---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ServiceContactForm from '../../components/ServiceContactForm.astro';
---

<Layout title="Tax Number (AFM) Greece | Taxomade">
  <!-- Section 1: Hero (Conversion Optimized) -->
  <div class="relative pt-32 pb-24 md:pt-40 md:pb-32 overflow-hidden bg-slate-50">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-white/80 via-white/50 to-slate-50/20"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Copy & CTAs -->
        <div class="max-w-2xl">
          <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 tracking-tight leading-tight">
            Get your Greek tax number <span class="text-blue-800">—</span> remote, in days.
          </h1>
          <p class="text-xl text-slate-600 mb-8 leading-relaxed">
            The AFM is your gateway to living, working and banking in Greece. We register it for you via power of attorney without you needing to travel.
          </p>
          
          <!-- Benefit Checkmarks -->
          <ul class="space-y-3 mb-10">
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              100% remote / no office visit
            </li>
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Fast turnaround (done in days)
            </li>
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Handled by licensed local experts
            </li>
            <li class="flex items-center text-slate-700 font-medium">
              <svg class="w-6 h-6 text-emerald-500 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              Fixed, transparent pricing
            </li>
          </ul>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 mb-4">
            <a href="/#configurator" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl text-white bg-slate-900 hover:bg-blue-800 transition-colors duration-200 shadow-md">
              Get started
            </a>
            <a href="#contact-form" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl text-slate-700 bg-white border-2 border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-colors duration-200">
              Talk to us
            </a>
          </div>
          <p class="text-sm text-slate-500 font-medium flex items-center">
            <svg class="w-4 h-4 text-slate-400 mr-1.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd"></path></svg>
            Trusted by remote workers moving to Greece
          </p>
        </div>
        
        <!-- Right: Visual Mockup -->
        <div class="hidden lg:flex justify-end relative">
          <div class="relative w-full max-w-md">
            <div class="absolute inset-0 bg-gradient-to-tr from-blue-100 to-emerald-50 rounded-3xl transform rotate-3 scale-105 opacity-50"></div>
            <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-10 relative overflow-hidden flex flex-col justify-center items-center text-center">
              <div class="w-20 h-20 bg-blue-50 rounded-2xl flex items-center justify-center mb-6">
                <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path></svg>
              </div>
              <h3 class="text-2xl font-bold text-slate-900 mb-2">AFM Registered</h3>
              <p class="text-slate-500">Your Greek Tax ID, ready to use.</p>
              <div class="mt-8 w-full flex justify-center">
                <div class="bg-blue-100 text-blue-800 font-mono text-xl font-bold px-6 py-3 rounded-lg border border-blue-200">
                  123456789
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <main class="py-20 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <!-- Section 2: Service Overview & Requirements -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
      <!-- What it is Card -->
      <section class="bg-white p-8 md:p-10 rounded-3xl border border-slate-200 shadow-sm relative overflow-hidden flex flex-col justify-center">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50 rounded-bl-full -z-0"></div>
        <div class="relative z-10">
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-blue-800 bg-blue-100 rounded-full">EU & Non-EU</span>
            <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-blue-800 bg-blue-100 rounded-full">Remote</span>
          </div>
          <h2 class="text-3xl font-bold text-slate-900 mb-4">The Essentials</h2>
          <p class="text-lg text-slate-700 leading-relaxed mb-6">
            The AFM (Αριθμός Φορολογικού Μητρώου) is your personal Greek tax identification number. It is the first and most important administrative step for anyone settling in Greece.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start text-slate-700">
              <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <strong>Rent an apartment:</strong> Landlords require it for the contract.
            </li>
            <li class="flex items-start text-slate-700">
              <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <strong>Open a bank account:</strong> Essential for any Greek bank.
            </li>
            <li class="flex items-start text-slate-700">
              <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              <strong>Freelance & Tax breaks:</strong> Needed to register your business or apply for 5C.
            </li>
          </ul>
        </div>
      </section>

      <!-- Requirements Card -->
      <section class="bg-slate-900 p-8 md:p-10 rounded-3xl shadow-sm text-white relative overflow-hidden flex flex-col justify-center">
        <div class="absolute top-0 right-0 w-32 h-32 bg-slate-800 rounded-bl-full -z-0"></div>
        <div class="relative z-10">
          <span class="inline-block px-3 py-1 mb-6 text-xs font-bold uppercase tracking-wider text-emerald-400 bg-emerald-400/10 rounded-full">Checklist</span>
          <h2 class="text-3xl font-bold mb-4">Eligibility & Prerequisites</h2>
          <p class="text-slate-300 mb-6">What we need from you to get started:</p>
          <ul class="space-y-4 text-lg text-slate-200">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>A valid passport or ID card.</strong></span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>Signed Power of Attorney:</strong> We provide the document for you to sign remotely.</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>Visa/Residence permit</strong> (only if you are a non-EU citizen).</span>
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <span><strong>No in-person visit required.</strong></span>
            </li>
          </ul>
        </div>
      </section>
    </div>

        <!-- Section 3: Split Timeline -->
    <section class="max-w-4xl mx-auto mb-24 px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight">How it works, <span class="text-slate-400">how little you do.</span></h2>
        <p class="text-lg text-slate-600">100% remote — we handle the bureaucracy.</p>
      </div>
      
      <div class="relative">
        <!-- Central Line -->
        <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-slate-200 -translate-x-1/2"></div>
        
        <!-- Step 1 -->
        <div class="relative flex flex-col md:flex-row items-center justify-between mb-16">
          <div class="md:w-[45%] mb-6 md:mb-0 md:text-right opacity-60">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-xs font-bold uppercase tracking-wider mb-3">
              <span class="mr-2 opacity-50">1 day</span> Your part
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Gather Info</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Send your passport scan and basic details.</p>
          </div>
          
          <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-white border-2 border-slate-300 text-slate-400 font-bold z-10 hidden md:flex">
            1
          </div>
          
          <div class="md:w-[45%] text-center md:text-left">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold uppercase tracking-wider mb-3">
              taxomade™
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Prep & PoA</h3>
            <p class="text-slate-600 text-sm leading-relaxed">We prepare your power of attorney and a simple checklist.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="relative flex flex-col md:flex-row items-center justify-between mb-16">
          <div class="md:w-[45%] mb-6 md:mb-0 md:text-right opacity-60">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-xs font-bold uppercase tracking-wider mb-3">
              <span class="mr-2 opacity-50">~10 min</span> Your part
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Sign Online</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Sign online via our certified notary partner — no office, no consulate.</p>
          </div>
          
          <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-white border-2 border-slate-300 text-slate-400 font-bold z-10 hidden md:flex">
            2
          </div>
          
          <div class="md:w-[45%] text-center md:text-left">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold uppercase tracking-wider mb-3">
              taxomade™
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Guidance</h3>
            <p class="text-slate-600 text-sm leading-relaxed">We set up and guide you through the online signature.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="relative flex flex-col md:flex-row items-center justify-between">
          <div class="md:w-[45%] mb-6 md:mb-0 md:text-right opacity-60">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-xs font-bold uppercase tracking-wider mb-3">
              <span class="mr-2 opacity-50">~2-3 days</span> Your part
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Sit back</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Nothing — sit back.</p>
          </div>
          
          <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-emerald-600 text-white font-bold border-2 border-emerald-600 z-10 hidden md:flex shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          </div>
          
          <div class="md:w-[45%] text-center md:text-left">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-100 text-emerald-800 text-xs font-bold uppercase tracking-wider mb-3">
              taxomade™
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Registration</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Our licensed accountant registers your AFM and sets up your tax portal access.</p>
          </div>
        </div>

      </div>
      
      <div class="mt-16 text-center">
        <p class="text-xl font-medium text-slate-700 mb-8 italic">"The only thing you do is a 10-minute online signature."</p>
        <a href="#contact-form" class="inline-flex items-center justify-center px-10 py-4 text-lg font-bold rounded-xl text-white bg-slate-900 hover:bg-blue-800 transition-colors duration-200 shadow-xl hover:-translate-y-1 transform">
          Start now
        </a>
      </div>
    </section>

    <!-- Pricing Package -->
    <section class="max-w-5xl mx-auto mb-24 px-4 sm:px-0">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Single Service -->
        <div class="bg-white rounded-3xl shadow-xl border border-slate-200 overflow-hidden relative transform transition duration-300 hover:-translate-y-1 hover:shadow-2xl">
          <div class="absolute top-0 left-0 w-full h-1 bg-blue-800"></div>
          <div class="p-8 h-full flex flex-col">
            <h3 class="text-2xl font-bold text-slate-900 mb-2">Greek Tax Number (AFM)</h3>
            <p class="text-slate-500 mb-6 flex-grow">Fast, remote registration of your Greek tax ID.</p>
            <div class="flex items-baseline mb-8">
              <span class="text-5xl font-black text-slate-900">€250</span>
              <span class="text-slate-500 ml-2">/ one-off</span>
            </div>
            <ul class="space-y-4 mb-8">
              <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-emerald-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Remote registration via PoA</li>
              <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-emerald-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Fast turnaround time</li>
              <li class="flex items-start text-slate-700"><svg class="w-5 h-5 text-emerald-500 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Fully managed by licensed partner</li>
            </ul>
            <a href="/#configurator" class="block w-full py-4 px-6 bg-slate-100 hover:bg-slate-200 text-slate-900 font-bold rounded-xl transition-colors duration-200 text-center">Get AFM only</a>
          </div>
        </div>

        <!-- Full Package -->
        <div class="bg-slate-900 rounded-3xl shadow-2xl border border-slate-800 overflow-hidden relative transform transition duration-300 hover:-translate-y-1 hover:shadow-blue-900/50">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500 rounded-bl-full opacity-20 -z-0"></div>
          <div class="absolute top-0 left-0 w-full h-1 bg-emerald-400"></div>
          <div class="p-8 h-full flex flex-col relative z-10">
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-400/20 text-emerald-400 text-xs font-bold uppercase tracking-wider mb-4 w-max">Most Popular</div>
            <h3 class="text-2xl font-bold text-white mb-2">The Complete Setup</h3>
            <p class="text-slate-400 mb-6 flex-grow">Everything you need to legally work and live in Greece.</p>
            <div class="flex items-baseline mb-8">
              <span class="text-5xl font-black text-white">Custom</span>
            </div>
            <ul class="space-y-4 mb-8 text-slate-300">
              <li class="flex items-start"><svg class="w-5 h-5 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> AFM Registration</li>
              <li class="flex items-start"><svg class="w-5 h-5 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Article 5C Application (50% Tax Break)</li>
              <li class="flex items-start"><svg class="w-5 h-5 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Freelancer / Company Setup</li>
              <li class="flex items-start"><svg class="w-5 h-5 text-emerald-400 mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Ongoing Bookkeeping</li>
            </ul>
            <a href="/#configurator" class="block w-full py-4 px-6 bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-bold rounded-xl transition-colors duration-200 text-center shadow-lg">Build Your Package</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-3xl mx-auto mb-24">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-10 text-center">FAQ</h2>
      <div class="space-y-6">
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Do EU citizens need an AFM?</h4>
          <p class="text-lg text-slate-700">Yes, if they live, work or do financial transactions in Greece.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Can I get it before moving?</h4>
          <p class="text-lg text-slate-700">Yes — we can register it remotely via power of attorney.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Is the AFM the same as registering as a freelancer?</h4>
          <p class="text-lg text-slate-700">No — the AFM comes first; freelancer registration is a separate step we also handle.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
          <h4 class="text-xl font-bold text-slate-900 mb-2">Do I need it if I stay under 6 months?</h4>
          <p class="text-lg text-slate-700">Often not for tax purposes, but you may still need it for banking or renting.</p>
        </div>
      </div>
    </section>

    <ServiceContactForm />

  </main>
  
  <Footer />
</Layout>
