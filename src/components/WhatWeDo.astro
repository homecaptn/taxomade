---
---
<section id="what-we-do" class="py-24 bg-white relative overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-blue-50 blur-3xl opacity-50 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-emerald-50 blur-3xl opacity-50 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Left Content -->
      <div>
        <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-50 text-blue-800 text-sm font-bold uppercase tracking-wider mb-6">
          End-to-End Relocation
        </div>
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-6 leading-tight">Your move to Greece, <span class="text-blue-800">made fast and easy.</span></h2>
        <p class="text-lg text-slate-600 mb-8 leading-relaxed">
          Forget the endless paperwork and confusing local authorities. With Taxomade, you can handle almost your entire setup directly from your laptop. We make your relocation fast, remote-friendly, and completely stress-free.
        </p>
        
        <div class="space-y-6">
          <div class="flex items-start">
            <div class="flex-shrink-0 h-12 w-12 rounded-xl bg-blue-100 flex items-center justify-center text-blue-800">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            </div>
            <div class="ml-4">
              <h3 class="text-xl font-bold text-slate-900">One-Stop Shop</h3>
              <p class="text-slate-600 mt-1">We don't just get you the visa. We set up your tax numbers, handle your health insurance, and do your bookkeeping.</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 h-12 w-12 rounded-xl bg-emerald-100 flex items-center justify-center text-emerald-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
            <div class="ml-4">
              <h3 class="text-xl font-bold text-slate-900">Maximize Tax Savings</h3>
              <p class="text-slate-600 mt-1">Greece offers massive incentives like the 50% Tax Break (Article 5C). We ensure you're eligible and apply on your behalf.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Content: For Whom (Bento Grid) -->
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-tr from-slate-100 to-slate-50 rounded-3xl transform rotate-3"></div>
        <div class="relative bg-white rounded-3xl shadow-xl border border-slate-100 p-8">
          <h3 class="text-2xl font-black text-slate-900 mb-6 border-b border-slate-100 pb-4">Who is this for?</h3>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            
            <!-- Target 1 -->
            <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
              <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-blue-800 shadow-sm mb-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <h4 class="font-bold text-slate-900">Freelancers</h4>
              <p class="text-xs text-slate-600 mt-1">Remote self-employed professionals needing local registration & accounting.</p>
            </div>

            <!-- Target 2 -->
            <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200">
              <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-emerald-600 shadow-sm mb-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <h4 class="font-bold text-slate-900">Remote Employees</h4>
              <p class="text-xs text-slate-600 mt-1">Working for a company abroad but moving your life and tax residency to Greece.</p>
            </div>

            <!-- Target 3 -->
            <div class="bg-slate-50 rounded-2xl p-5 border border-slate-200 sm:col-span-2 flex items-center justify-between">
              <div>
                <h4 class="font-bold text-slate-900">EU & Non-EU Citizens</h4>
                <p class="text-xs text-slate-600 mt-1">We handle both paths. <span class="font-semibold text-blue-800">No visa needed for EU citizens.</span></p>
              </div>
              <div class="flex -space-x-2">
                <div class="w-10 h-10 rounded-full border-2 border-white bg-blue-100 flex items-center justify-center text-blue-800 font-bold text-xs shadow-sm">EU</div>
                <div class="w-10 h-10 rounded-full border-2 border-white bg-slate-800 flex items-center justify-center text-white font-bold text-[10px] shadow-sm leading-tight text-center">NON<br>EU</div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>
