---
---
<section id="countries" class="py-24 bg-slate-50 border-t border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Supported Countries</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">We are expanding our network of licensed local accountants and lawyers.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      
      <!-- Greece -->
      <a href="#configurator" class="group block relative rounded-3xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 border-2 border-transparent hover:border-blue-800">
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent z-10"></div>
        <img src="https://images.unsplash.com/photo-1516483638261-f40889f08a63?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Greece" class="w-full h-80 object-cover group-hover:scale-105 transition-transform duration-700" />
        <div class="absolute bottom-0 left-0 p-6 z-20 w-full flex justify-between items-end">
          <div>
            <h3 class="text-2xl font-bold text-white mb-1">Greece</h3>
            <p class="text-slate-300 text-sm">Fully active</p>
          </div>
          <div class="bg-blue-800 text-slate-900 rounded-lg p-2 group-hover:rotate-45 transition-transform duration-300">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </div>
        </div>
      </a>

      <!-- Spain -->
      <a href="#contact" class="group block relative rounded-3xl overflow-hidden border border-slate-200 hover:border-slate-300 transition-all">
        <div class="absolute inset-0 bg-slate-900/60 z-10 backdrop-blur-[2px] group-hover:backdrop-blur-none transition-all duration-500"></div>
        <img src="https://images.unsplash.com/photo-1543783207-ec64e4d95325?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Spain" class="w-full h-80 object-cover grayscale group-hover:grayscale-0 transition-all duration-700" />
        <div class="absolute top-6 left-6 z-20">
          <span class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-3 py-1.5 rounded-lg border border-white/30">Coming soon</span>
        </div>
        <div class="absolute bottom-0 left-0 p-6 z-20">
          <h3 class="text-2xl font-bold text-white mb-1">Spain</h3>
          <p class="text-slate-200 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">Join waitlist</p>
        </div>
      </a>

      <!-- Italy -->
      <a href="#contact" class="group block relative rounded-3xl overflow-hidden border border-slate-200 hover:border-slate-300 transition-all">
        <div class="absolute inset-0 bg-slate-900/60 z-10 backdrop-blur-[2px] group-hover:backdrop-blur-none transition-all duration-500"></div>
        <img src="https://images.unsplash.com/photo-1515542622106-78bda8ba0e5b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Italy" class="w-full h-80 object-cover grayscale group-hover:grayscale-0 transition-all duration-700" />
        <div class="absolute top-6 left-6 z-20">
          <span class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-3 py-1.5 rounded-lg border border-white/30">Coming soon</span>
        </div>
        <div class="absolute bottom-0 left-0 p-6 z-20">
          <h3 class="text-2xl font-bold text-white mb-1">Italy</h3>
          <p class="text-slate-200 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">Join waitlist</p>
        </div>
      </a>

      <!-- Bulgaria -->
      <a href="#contact" class="group block relative rounded-3xl overflow-hidden border border-slate-200 hover:border-slate-300 transition-all">
        <div class="absolute inset-0 bg-slate-900/60 z-10 backdrop-blur-[2px] group-hover:backdrop-blur-none transition-all duration-500"></div>
        <img src="https://images.unsplash.com/photo-1550570783-057bfd2105e1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Bulgaria" class="w-full h-80 object-cover grayscale group-hover:grayscale-0 transition-all duration-700" />
        <div class="absolute top-6 left-6 z-20">
          <span class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-3 py-1.5 rounded-lg border border-white/30">Coming soon</span>
        </div>
        <div class="absolute bottom-0 left-0 p-6 z-20">
          <h3 class="text-2xl font-bold text-white mb-1">Bulgaria</h3>
          <p class="text-slate-200 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">Join waitlist</p>
        </div>
      </a>

    </div>
  </div>
</section>
