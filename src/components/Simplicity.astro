---
---
<section class="py-24 bg-white border-b border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      
      <div>
        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6 leading-tight">
          Keep it <span class="text-blue-800">simple</span>.
        </h2>
        <p class="text-lg text-slate-600 mb-8 max-w-lg">
          No confusing portals, no endless email threads, no bureaucracy. We manage everything through the tools you already use every day.
        </p>
        
        <ul class="space-y-4">
          <li class="flex items-center">
            <svg class="w-6 h-6 text-slate-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-slate-700 font-medium">Direct WhatsApp / Telegram support</span>
          </li>
          <li class="flex items-center">
            <svg class="w-6 h-6 text-slate-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-slate-700 font-medium">Snap a photo of invoices, we do the rest</span>
          </li>
          <li class="flex items-center">
            <svg class="w-6 h-6 text-slate-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-slate-700 font-medium">Instant answers from local experts</span>
          </li>
        </ul>
      </div>

      <div class="relative">
        <div class="absolute -inset-4 bg-slate-50 rounded-3xl -z-10"></div>
        <div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-6 flex flex-col space-y-4">
          <!-- Chat mockup -->
          <div class="flex items-end">
            <div class="bg-slate-100 rounded-2xl rounded-bl-sm p-4 max-w-[80%]">
              <p class="text-sm text-slate-900">Hey! I just signed a new client. Do I need to issue an invoice before or after they pay?</p>
            </div>
          </div>
          <div class="flex items-end justify-end">
            <div class="bg-blue-800 rounded-2xl rounded-br-sm p-4 max-w-[80%] text-white">
              <p class="text-sm">Congrats! 🎉 Just send us their details here, we will generate the e-invoice and send you the PDF right away.</p>
            </div>
          </div>
          <div class="flex items-end">
            <div class="bg-slate-100 rounded-2xl rounded-bl-sm p-4 max-w-[80%]">
              <p class="text-sm text-slate-900">Awesome, here's their VAT number: EL999888777.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
