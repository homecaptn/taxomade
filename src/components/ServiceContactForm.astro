---
// src/components/ServiceContactForm.astro
---
<section class="max-w-4xl mx-auto mb-24 bg-slate-900 rounded-3xl p-8 md:p-12 text-white shadow-xl relative overflow-hidden" id="contact-form">
  <div class="absolute top-0 right-0 w-64 h-64 bg-slate-800 rounded-bl-full -z-0"></div>
  <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <div>
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to get started?</h2>
      <p class="text-slate-300 mb-8 text-lg">Send us a message and our local experts will get back to you with the next steps.</p>
      
      <ul class="space-y-4 mb-8">
        <li class="flex items-center text-slate-200">
          <svg class="w-6 h-6 text-emerald-400 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          No commitment required
        </li>
        <li class="flex items-center text-slate-200">
          <svg class="w-6 h-6 text-emerald-400 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Plain-English support
        </li>
        <li class="flex items-center text-slate-200">
          <svg class="w-6 h-6 text-emerald-400 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Secure document handling
        </li>
      </ul>
    </div>
    
    <div class="bg-white p-6 md:p-8 rounded-2xl text-slate-900 shadow-md">
      <div id="service-contact-success" class="flex-col items-center justify-center text-center hidden py-8 min-h-[250px]">
        <div class="flex items-center justify-center space-x-3 mb-4">
          <div class="w-10 h-10 bg-green-100 text-green-600 rounded-full flex items-center justify-center shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          </div>
          <h3 class="text-2xl md:text-3xl font-bold text-slate-900">Request sent</h3>
        </div>
        <p class="text-slate-600">Thanks for reaching out. We've received your message and will get back to you shortly.</p>
      </div>

      <form id="service-contact-form" class="space-y-4">
        <input type="hidden" name="destination" value="greece" />
        <input type="hidden" name="configurator_data" value="" />
        <input type="hidden" name="_autoresponse" value="Hi there,

Thank you for reaching out to Taxomade! We've received your request and one of us will personally get back to you very shortly.

In the meantime, sit back and relax — handling the paperwork is our job. We're looking forward to helping you make your move to Greece simple and stress-free.

Talk soon,
Leonard & Manoli
Taxomade™ — The Tax Nomad Setup
info@taxomade.com" />

        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1" for="name">Name</label>
          <input type="text" id="name" name="name" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-800 focus:border-transparent transition-all" placeholder="Jane Doe" required>
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1" for="email">Email</label>
          <input type="email" id="email" name="email" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-800 focus:border-transparent transition-all" placeholder="jane@example.com" required>
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1" for="message">Message</label>
          <textarea id="message" name="message" rows="3" class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-800 focus:border-transparent transition-all" placeholder="Tell us about your situation..." required></textarea>
        </div>
        <button type="submit" id="service-submit-btn" class="w-full bg-blue-800 hover:bg-slate-900 text-white font-bold py-4 rounded-xl transition-colors duration-200 shadow-sm mt-2">
          Contact Now
        </button>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('service-contact-form');
    const successMsg = document.getElementById('service-contact-success');
    const submitBtn = document.getElementById('service-submit-btn');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Push GTM event as requested
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({'event': 'form_submit_success'});

        const originalBtnText = submitBtn.innerText;
        submitBtn.innerText = 'Sending...';
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
          const res = await fetch('/api/submitContactForm', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
          });

          if (res.ok) {
            form.style.display = 'none';
            successMsg.classList.remove('hidden');
            successMsg.classList.add('flex');
          } else {
            alert('Something went wrong. Please try again.');
            submitBtn.innerText = originalBtnText;
            submitBtn.disabled = false;
          }
        } catch (err) {
          console.error(err);
          alert('Failed to connect to the server. Please try again.');
          submitBtn.innerText = originalBtnText;
          submitBtn.disabled = false;
        }
      });
    }
  });
</script>
