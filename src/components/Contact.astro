---
---
<section id="contact" class="py-24 bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Let's get started</h2>
      <p class="text-lg text-slate-600">Fill out the form below or book a free consultation call.</p>
    </div>

    <div class="bg-slate-50 p-8 md:p-10 rounded-3xl border border-slate-100 shadow-sm relative overflow-hidden">
      <div id="contact-success" class="absolute inset-0 bg-slate-50 z-10 flex flex-col items-center justify-center p-8 text-center hidden">
        <div class="w-24 h-24 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-8">
          <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <h3 class="text-4xl font-bold text-slate-900 mb-4">Request sent!</h3>
        <p class="text-xl text-slate-600 max-w-md mx-auto">Thanks for reaching out. We've received your message and will get back to you shortly.</p>
      </div>

      <form id="contact-form" class="space-y-6">
        <input type="hidden" id="contact-config-data" name="configurator_data" value="" />
        <input type="hidden" name="_autoresponse" value="Hi there,

Thank you for reaching out to Taxomade! We've received your request and one of us will personally get back to you very shortly.

In the meantime, sit back and relax — handling the paperwork is our job. We're looking forward to helping you make your move to Greece simple and stress-free.

Talk soon,
Leonard & Manoli
Taxomade™ — The Tax Nomad Setup
info@taxomade.com">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-800 focus:border-blue-800 transition-colors" placeholder="Jane Doe" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email Address</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-800 focus:border-blue-800 transition-colors" placeholder="jane@example.com" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="origin" class="block text-sm font-medium text-slate-700 mb-1">Current Country</label>
            <input type="text" id="origin" name="origin" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-800 focus:border-blue-800 transition-colors" placeholder="e.g. USA, Germany" />
          </div>
          <div>
            <label for="destination" class="block text-sm font-medium text-slate-700 mb-1">Destination</label>
            <select id="destination" name="destination" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-800 focus:border-blue-800 transition-colors bg-white">
              <option value="greece">Greece</option>
              <option value="spain">Spain (Waitlist)</option>
              <option value="italy">Italy (Waitlist)</option>
              <option value="bulgaria">Bulgaria (Waitlist)</option>
            </select>
          </div>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-slate-700 mb-1">How can we help?</label>
          <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-800 focus:border-blue-800 transition-colors" placeholder="Tell us a bit about your situation..."></textarea>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <button type="submit" id="submit-btn" class="flex-1 bg-slate-900 hover:bg-brand-700 text-white font-medium py-3.5 px-8 rounded-lg shadow-md transition-colors text-center">
            Send Request
          </button>
          <a href="/call" class="flex-1 bg-white hover:bg-slate-50 text-slate-900 border border-slate-200 font-medium py-3.5 px-8 rounded-lg shadow-sm transition-colors text-center flex items-center justify-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            Book a free call
          </a>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const successMsg = document.getElementById('contact-success');
    const submitBtn = document.getElementById('submit-btn');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Push GTM event as requested
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({'event': 'form_submit_success'});

        const originalBtnText = submitBtn.innerText;
        submitBtn.innerText = 'Sending...';
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
          const res = await fetch('/api/submitContactForm', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
          });

          if (res.ok) {
            form.style.display = 'none';
            successMsg.classList.remove('hidden');
          } else {
            alert('Something went wrong. Please try again.');
            submitBtn.innerText = originalBtnText;
            submitBtn.disabled = false;
          }
        } catch (err) {
          console.error(err);
          alert('Failed to connect to the server. Please try again.');
          submitBtn.innerText = originalBtnText;
          submitBtn.disabled = false;
        }
      });
    }
  });
</script>
