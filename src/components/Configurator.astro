---
---
<section id="configurator" class="py-20 bg-slate-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Discover your path to Greece</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Answer four quick questions to find out exactly which steps and services apply to your personal situation.</p>
    </div>
    
    <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-8 md:p-12 min-h-[600px] relative flex flex-col" id="conf-content">
      
      <!-- Header / Progress Area -->
      <div class="mb-10 w-full">
        <div class="flex items-center justify-between text-sm font-bold text-slate-500 mb-3 uppercase tracking-wider">
          <span id="conf-progress-text">Step 1 of 4</span>
          <span id="conf-progress-pct" class="text-blue-600">0%</span>
        </div>
        <div class="w-full bg-slate-100 h-2.5 rounded-full overflow-hidden mb-6">
          <div id="conf-progress-bar" class="bg-blue-600 h-full rounded-full transition-all duration-500" style="width: 0%"></div>
        </div>
        <div id="conf-chips" class="flex flex-wrap gap-2 mb-6 empty:hidden"></div>
        <button id="conf-back" type="button" class="text-slate-500 hover:text-slate-800 transition-colors hidden font-medium flex items-center w-fit">
          <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back
        </button>
      </div>
        
        <!-- Step 1: Origin -->
        <div class="conf-step active" id="step-1">
          <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-left">Where are you from?</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="1" data-val="noneu">
              <span class="block font-semibold">I'm from outside the EU</span>
            </button>
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="1" data-val="eu">
              <span class="block font-semibold">I'm from the EU</span>
            </button>
          </div>
          <div class="mt-8 bg-blue-50/50 p-4 rounded-xl border border-blue-100 flex items-start text-sm text-slate-600">
            <svg class="w-5 h-5 text-blue-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p><span class="font-bold text-slate-700">Why we ask this:</span> This determines if you need a visa to enter and live in Greece.</p>
          </div>
        </div>

        <!-- Step 2: Duration -->
        <div class="conf-step hidden" id="step-2">
          <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-left">How long do you plan to stay in Greece?</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="2" data-val="short">
              <span class="block font-semibold">Less than 6 months</span>
            </button>
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="2" data-val="long">
              <span class="block font-semibold">6 months or more</span>
            </button>
          </div>
          <div class="mt-8 bg-blue-50/50 p-4 rounded-xl border border-blue-100 flex items-start text-sm text-slate-600">
            <svg class="w-5 h-5 text-blue-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p><span class="font-bold text-slate-700">Why we ask this:</span> This determines your tax residency status and if you need to register locally for taxes.</p>
          </div>
        </div>

        <!-- Step 3: Employment -->
        <div class="conf-step hidden" id="step-3">
          <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-left">How will you be working?</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="3" data-val="freelance">
              <span class="block font-semibold">As a freelancer / self-employed</span>
            </button>
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="3" data-val="employed">
              <span class="block font-semibold">Employed remotely for a company abroad</span>
            </button>
          </div>
          <div class="mt-8 bg-blue-50/50 p-4 rounded-xl border border-blue-100 flex items-start text-sm text-slate-600">
            <svg class="w-5 h-5 text-blue-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p><span class="font-bold text-slate-700">Why we ask this:</span> Freelancers have different ongoing reporting and bookkeeping obligations in Greece compared to remote employees.</p>
          </div>
        </div>

        <!-- Step 4: Income -->
        <div class="conf-step hidden" id="step-4">
          <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-left">Roughly what's your net annual income?</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="4" data-val="low">
              <span class="block font-semibold">Under €25,000</span>
            </button>
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="4" data-val="mid">
              <span class="block font-semibold">€25,000–42,000</span>
            </button>
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="4" data-val="high">
              <span class="block font-semibold">€42,000–70,000</span>
            </button>
            <button type="button" class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="4" data-val="highest">
              <span class="block font-semibold">Over €70,000</span>
            </button>
          </div>
          <div class="mt-8 bg-blue-50/50 p-4 rounded-xl border border-blue-100 flex items-start text-sm text-slate-600">
            <svg class="w-5 h-5 text-blue-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p id="income-why-text"><span class="font-bold text-slate-700">Why we ask this:</span> This determines your eligibility for the 50% Tax Break (Article 5C) and whether you meet the financial threshold for the Digital Nomad Visa.</p>
          </div>
        </div>

        <!-- Result Step -->
        <div class="conf-step hidden" id="step-result">
          <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-2 text-center" id="result-title">Here's what you need for your move to Greece.</h3>
          <p class="text-left text-slate-600 mb-8" id="result-subtitle">Based on your answers, here is exactly what applies to you:</p>
          
          <div id="result-list" class="space-y-4 mb-8">
            <!-- Populated by JS -->
          </div>

          <div class="text-center space-y-4">
            <button type="button" onclick="document.getElementById('contact')?.scrollIntoView({behavior: 'smooth'})" class="inline-flex w-full sm:w-auto items-center justify-center px-8 py-3.5 text-base font-medium rounded-lg text-white bg-blue-800 hover:bg-blue-900 shadow-md transition-all duration-200 cursor-pointer">
              Request your quote
            </button>
            <p class="text-sm text-slate-500" id="result-hint">Scroll down to see more details about these services.</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  let historyStack: number[] = [1];
  const totalSteps = 4;
  let answers = {
    origin: '',
    duration: '',
    employment: '',
    income: ''
  };

  const labelMap: Record<string, string> = {
    noneu: 'Non-EU',
    eu: 'EU',
    short: '< 6 Months',
    long: '6+ Months',
    freelance: 'Freelance',
    employed: 'Employed',
    low: '< €25k',
    mid: '€25k-42k',
    high: '€42k-70k',
    highest: '> €70k'
  };

  function renderChips() {
    const container = document.getElementById('conf-chips');
    if (!container) return;
    container.innerHTML = '';
    
    const orderedKeys = ['origin', 'duration', 'employment', 'income'] as const;
    
    orderedKeys.forEach(key => {
      const val = answers[key];
      if (val && labelMap[val]) {
        const chip = document.createElement('div');
        chip.className = 'inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-slate-100 text-slate-700 border border-slate-200';
        chip.innerHTML = `<svg class="w-4 h-4 text-blue-600 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>${labelMap[val]}`;
        container.appendChild(chip);
      }
    });
  }

  const backBtn = document.getElementById('conf-back');

  document.querySelectorAll('.conf-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const el = e.currentTarget as HTMLButtonElement;
      const step = parseInt(el.getAttribute('data-step') || '1');
      const val = el.getAttribute('data-val') || '';

      if (step === 1) {
        answers.origin = val;
        nextStep(2);
      } else if (step === 2) {
        answers.duration = val;
        nextStep(3);
      } else if (step === 3) {
        answers.employment = val;
        nextStep(4);
      } else if (step === 4) {
        answers.income = val;
        showResults();
      }
      renderChips();
      window.dispatchEvent(new CustomEvent('taxomade:answer-change', { detail: answers }));
    });
  });

  backBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    if (historyStack.length > 1) {
      historyStack.pop(); // Remove current
      const prevStep = historyStack[historyStack.length - 1];
      
      // Clear future answers when going back
      if (prevStep <= 4) answers.income = '';
      if (prevStep <= 3) answers.employment = '';
      if (prevStep <= 2) answers.duration = '';
      if (prevStep <= 1) answers.origin = '';
      
      renderChips();
      showStep(prevStep);
      window.dispatchEvent(new CustomEvent('taxomade:answer-change', { detail: answers }));
    }
  });

  function nextStep(step: number) {
    historyStack.push(step);
    showStep(step);
  }

  function showStep(step: number) {
    document.querySelectorAll('.conf-step').forEach(el => el.classList.add('hidden'));
    
    document.getElementById(`step-${step}`)?.classList.remove('hidden');
    
    const progressText = document.getElementById('conf-progress-text');
    const progressPct = document.getElementById('conf-progress-pct');
    const progressBar = document.getElementById('conf-progress-bar');
    
    if (progressText) progressText.innerText = `Step ${step} of ${totalSteps}`;
    
    let pct = Math.round(((step - 1) / totalSteps) * 100);
    if (pct < 0) pct = 0;
    if (pct > 100) pct = 100;
    
    if (progressPct) progressPct.innerText = `${pct}%`;
    if (progressBar) progressBar.style.width = `${pct}%`;
    
    if (step === 4) {
      const whyText = document.getElementById('income-why-text');
      if (whyText) {
        if (answers.origin === 'noneu') {
          whyText.innerHTML = '<span class="font-bold text-slate-700">Why we ask this:</span> This determines if you meet the financial threshold for the Digital Nomad Visa.';
        } else {
          whyText.innerHTML = '<span class="font-bold text-slate-700">Why we ask this:</span> This helps us calculate your potential savings from the 50% Tax Break (Article 5C).';
        }
      }
    }

    const backBtn = document.getElementById('conf-back');
    if (backBtn) {
      if (historyStack.length > 1) {
        backBtn.classList.remove('hidden');
      } else {
        backBtn.classList.add('hidden');
      }
    }
  }

  function showResults() {
    document.querySelectorAll('.conf-step').forEach(el => el.classList.add('hidden'));
    document.getElementById('step-result')?.classList.remove('hidden');
    document.getElementById('conf-progress-text')!.innerText = 'Recommendation';
    document.getElementById('conf-progress-pct')!.innerText = '100%';
    document.getElementById('conf-progress-bar')!.style.width = '100%';
    document.getElementById('conf-back')?.classList.remove('hidden');
    historyStack.push(100); // dummy for result

    const resultList = document.getElementById('result-list');
    const resultSubtitle = document.getElementById('result-subtitle');
    const resultHint = document.getElementById('result-hint');
    if (!resultList || !resultSubtitle) return;
    
    let html = '';
    
    if (answers.duration === 'short') {
      resultSubtitle.innerText = "Based on your answers, you'll need very little — here's what applies:";
      if (resultHint) resultHint.classList.add('hidden');
    } else {
      resultSubtitle.innerText = "Based on your answers, here is exactly what applies to you:";
      if (resultHint) resultHint.classList.remove('hidden');
    }

    // 1. Visa
    if (answers.origin === 'noneu') {
      if (answers.duration === 'long') {
        if (answers.income === 'low' || answers.income === 'mid') {
          html += createResultItem('Visa Requirements Not Met', "Unfortunately, you don't fulfill the financial requirements for the Digital Nomad Visa. You need at least €42,000 net annual income (€3,500/month) to qualify.", false, false, true);
        } else {
          html += createResultItem('Digital Nomad Visa', "You qualify for a Digital Nomad Visa — apply 1–2 months before you move. We handle the full application.", true);
        }
      } else {
        html += createResultItem('Visa requirements', "If you stay under 90 days you likely don't need a visa; between 90 days and 6 months you may need a short-stay visa — talk to us.");
      }
      // Insurance is strictly required for visas
      html += createResultItem('Health Insurance', 'Private health insurance is required for your visa. We can sort that out for you.');
    }

    // 2. AFM & Registration
    if (answers.duration === 'long') {
      html += createResultItem('Tax Number & Registration', "You'll need a Greek tax number (AFM) and to register your activity — we set this up for you.");
    } else {
      html += createResultItem('No Registration needed', "You likely won't need to register or pay Greek tax — you stay below the tax-residency threshold.");
    }

    // 3. 5C
    if (answers.duration === 'long') {
      if (answers.income === 'high' || answers.income === 'highest') {
        html += createResultItem('50% Tax Break (5C)', 'Strongly recommended — the 5C regime exempts 50% of your Greek income from tax for 7 years. At your income this saves you several thousand euros per year. Apply by July 31.', true);
      } else if (answers.income === 'mid') {
        html += createResultItem('50% Tax Break (5C)', "Worth considering — 5C still gives meaningful savings. We'll calculate if it's worth it for you.", true);
      } else {
        html += createResultItem('50% Tax Break (5C)', 'Optional — savings are smaller at your income level, but still available.', false, true);
      }
    }

    // 4. Bookkeeping
    if (answers.duration === 'long') {
      if (answers.employment === 'freelance') {
        html += createResultItem('Full Bookkeeping', 'Recommended — monthly bookkeeping & tax compliance (myDATA, EFKA, VAT, year-end, and the mandatory e-invoicing from Oct 2026). We handle it all in English.', true);
      } else {
        html += createResultItem('Annual Tax Return', "You'll need an annual Greek tax return — we handle that for you.");
      }
    }

    resultList.innerHTML = html;
    
    const inputConfig = document.getElementById('contact-config-data') as HTMLInputElement;
    if (inputConfig) {
      inputConfig.value = JSON.stringify(answers);
    }

    window.dispatchEvent(new CustomEvent('taxomade:configurator-complete', { detail: answers }));
  }

  function createResultItem(title: string, desc: string, highlight = false, optional = false, warning = false) {
    const bgClass = warning ? 'bg-red-50 border-red-200' : (highlight ? 'bg-slate-100 border-slate-300' : 'bg-slate-50 border-slate-100');
    const iconColor = warning ? 'text-red-500' : (highlight ? 'text-blue-800' : 'text-slate-500');
    
    let tag = '';
    if (warning) tag = '<span class="ml-2 text-xs font-bold text-red-600 uppercase tracking-wider bg-white px-2 py-0.5 rounded border border-red-200">Not Eligible</span>';
    else if (highlight) tag = '<span class="ml-2 text-xs font-bold text-blue-800 uppercase tracking-wider bg-white px-2 py-0.5 rounded border border-blue-200">Recommended</span>';
    else if (optional) tag = '<span class="ml-2 text-xs font-medium text-slate-500 uppercase tracking-wider bg-white px-2 py-0.5 rounded border border-slate-200">Optional</span>';
    
    const iconPath = warning 
      ? 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z'
      : 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z';

    return `
      <div class="p-4 rounded-xl border ${bgClass} flex items-start">
        <svg class="w-6 h-6 ${iconColor} flex-shrink-0 mt-0.5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${iconPath}"></path></svg>
        <div>
          <h4 class="font-bold text-slate-900 flex items-center flex-wrap gap-y-1">${title}${tag}</h4>
          <p class="text-sm text-slate-600 mt-1 leading-relaxed">${desc}</p>
        </div>
      </div>
    `;
  }
</script>
