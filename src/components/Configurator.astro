---
---
<section id="configurator" class="py-20 bg-slate-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Discover your path to Greece</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Answer five quick questions to find out exactly which steps and services apply to your personal situation.</p>
    </div>
    
    <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-8 md:p-12 min-h-[500px] relative flex flex-col" id="conf-content">
      
      <!-- Header / Progress Area -->
      <div class="mb-10 w-full">
        <div class="flex items-center justify-between text-sm font-bold text-slate-500 mb-3 uppercase tracking-wider">
          <span id="conf-progress-text">Step 1 of 5</span>
          <span id="conf-progress-pct" class="text-blue-600">0%</span>
        </div>
        <div class="w-full bg-slate-100 h-2.5 rounded-full overflow-hidden mb-6">
          <div id="conf-progress-bar" class="bg-blue-600 h-full rounded-full transition-all duration-500" style="width: 0%"></div>
        </div>
                <div id="conf-chips" class="flex flex-wrap gap-2 mb-6 empty:hidden"></div>
        <button id="conf-back" class="text-slate-500 hover:text-slate-800 transition-colors hidden font-medium flex items-center w-fit">
          <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back
        </button>
      </div>
        
        <!-- Step 1: Destination -->
        <div class="conf-step active" id="step-1">
          <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-left">Where are you moving to?</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="1" data-val="greece">
              <span class="block text-xl mb-1">🇬🇷</span>
              <span class="block font-semibold">Greece</span>
            </button>
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2 opacity-70" data-step="1" data-val="other">
              <span class="block text-xl mb-1">🇪🇸 🇮🇹 🇧🇬</span>
              <span class="block font-semibold">Spain, Italy, Bulgaria</span>
              <span class="block text-xs text-blue-800 font-medium mt-1 uppercase tracking-wider">Coming soon</span>
            </button>
          </div>
        </div>

        <!-- Early Exit (Other Countries) -->
        <div class="conf-step hidden" id="step-early-exit">
          <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4 text-center">We're launching here soon!</h3>
          <p class="text-left text-slate-600 mb-8">We are currently focused on Greece, but we are launching our services in Spain, Italy, and Bulgaria very soon. Leave your details and we'll reach out when we're ready.</p>
          <div class="text-center">
            <a href="#contact" class="inline-flex w-full sm:w-auto items-center justify-center px-8 py-3.5 text-base font-medium rounded-lg text-white bg-blue-800 hover:bg-blue-900 shadow-md transition-all duration-200">
              Get notified
            </a>
          </div>
        </div>

        <!-- Step 2: Origin -->
        <div class="conf-step hidden" id="step-2">
          <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-left">Where are you from?</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="2" data-val="noneu">
              <span class="block font-semibold">I'm from outside the EU</span>
            </button>
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="2" data-val="eu">
              <span class="block font-semibold">I'm from the EU</span>
            </button>
          </div>
        </div>

        <!-- Step 3: Duration -->
        <div class="conf-step hidden" id="step-3">
          <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-left">How long do you plan to stay in Greece?</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="3" data-val="short">
              <span class="block font-semibold">Less than 6 months</span>
            </button>
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="3" data-val="long">
              <span class="block font-semibold">6 months or more</span>
            </button>
          </div>
        </div>

        <!-- Step 4: Employment -->
        <div class="conf-step hidden" id="step-4">
          <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-left">How will you be working?</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="4" data-val="freelance">
              <span class="block font-semibold">As a freelancer / self-employed</span>
            </button>
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="4" data-val="employed">
              <span class="block font-semibold">Employed remotely for a company abroad</span>
            </button>
          </div>
        </div>

        <!-- Step 5: Income -->
        <div class="conf-step hidden" id="step-5">
          <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 text-left">Roughly what's your annual income?</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="5" data-val="low">
              <span class="block font-semibold">Under €25,000</span>
            </button>
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="5" data-val="mid">
              <span class="block font-semibold">€25,000–40,000</span>
            </button>
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="5" data-val="high">
              <span class="block font-semibold">€40,000–70,000</span>
            </button>
            <button class="conf-btn p-6 border border-slate-200 rounded-lg bg-white text-left transition-all duration-200 hover:border-blue-600 hover:shadow-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2" data-step="5" data-val="highest">
              <span class="block font-semibold">Over €70,000</span>
            </button>
          </div>
        </div>

        <!-- Result Step -->
        <div class="conf-step hidden" id="step-result">
          <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-2 text-center" id="result-title">Here's what you need for your move to Greece.</h3>
          <p class="text-left text-slate-600 mb-8" id="result-subtitle">Based on your answers, here is exactly what applies to you:</p>
          
          <div id="result-list" class="space-y-4 mb-8">
            <!-- Populated by JS -->
          </div>

          <div class="text-center space-y-4">
            <a href="#contact" class="inline-flex w-full sm:w-auto items-center justify-center px-8 py-3.5 text-base font-medium rounded-lg text-white bg-blue-800 hover:bg-blue-900 shadow-md transition-all duration-200">
              Request your quote
            </a>
            <p class="text-sm text-slate-500" id="result-hint">Scroll down to see more details about these services.</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  let historyStack: number[] = [1];
  const totalSteps = 5;
  let answers = {
    destination: '',
    origin: '',
    duration: '',
    employment: '',
    income: ''
  };

  
  const labelMap: Record<string, string> = {
    greece: 'Greece',
    noneu: 'Non-EU',
    eu: 'EU',
    short: '< 6 Months',
    long: '6+ Months',
    freelance: 'Freelance',
    employed: 'Employed',
    low: '< €25k',
    mid: '€25k-40k',
    high: '€40k-70k',
    highest: '> €70k'
  };

  function renderChips() {
    const container = document.getElementById('conf-chips');
    if (!container) return;
    container.innerHTML = '';
    
    const orderedKeys = ['destination', 'origin', 'duration', 'employment', 'income'] as const;
    
    orderedKeys.forEach(key => {
      const val = answers[key];
      if (val && labelMap[val]) {
        const chip = document.createElement('div');
        chip.className = 'inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-slate-100 text-slate-700 border border-slate-200';
        chip.innerHTML = `<svg class="w-4 h-4 text-blue-600 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>${labelMap[val]}`;
        container.appendChild(chip);
      }
    });
  }

  const backBtn = document.getElementById('conf-back');
  const progressText = document.getElementById('conf-progress');

  document.querySelectorAll('.conf-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const el = e.currentTarget as HTMLButtonElement;
      const step = parseInt(el.getAttribute('data-step') || '1');
      const val = el.getAttribute('data-val') || '';

      if (step === 1) {
        answers.destination = val;
        if (val === 'other') {
          showEarlyExit(); renderChips();
          window.dispatchEvent(new CustomEvent('taxomade:answer-change', { detail: answers }));
          return;
        }
        nextStep(2); renderChips();
      } else if (step === 2) {
        answers.origin = val;
        nextStep(3); renderChips();
      } else if (step === 3) {
        answers.duration = val;
        if (val === 'short') {
          showResults(); renderChips();
        } else {
          nextStep(4); renderChips();
        }
      } else if (step === 4) {
        answers.employment = val;
        nextStep(5); renderChips();
      } else if (step === 5) {
        answers.income = val;
        showResults(); renderChips();
      }
      
      window.dispatchEvent(new CustomEvent('taxomade:answer-change', { detail: answers }));
    });
  });

    backBtn?.addEventListener('click', () => {
    if (historyStack.length > 1) {
      historyStack.pop(); // Remove current
      const prevStep = historyStack[historyStack.length - 1];
      
      // Clear future answers when going back
      if (prevStep <= 4) answers.income = '';
      if (prevStep <= 3) answers.employment = '';
      if (prevStep <= 2) answers.duration = '';
      if (prevStep <= 1) answers.origin = '';
      if (prevStep === 1) answers.destination = '';
      
      renderChips();
      showStep(prevStep);
      window.dispatchEvent(new CustomEvent('taxomade:answer-change', { detail: answers }));
    }
  });

  function nextStep(step: number) {
    historyStack.push(step);
    showStep(step);
  }

  function showStep(step: number) {
    document.querySelectorAll('.conf-step').forEach(el => el.classList.add('hidden'));
    
    document.getElementById(`step-${step}`)?.classList.remove('hidden');
    
    const progressText = document.getElementById('conf-progress-text');
    const progressPct = document.getElementById('conf-progress-pct');
    const progressBar = document.getElementById('conf-progress-bar');
    
    if (progressText) progressText.innerText = `Step ${step} of ${totalSteps}`;
    
    let pct = Math.round(((step - 1) / totalSteps) * 100);
    if (pct < 0) pct = 0;
    if (pct > 100) pct = 100;
    
    if (progressPct) progressPct.innerText = `${pct}%`;
    if (progressBar) progressBar.style.width = `${pct}%`;
    
    const backBtn = document.getElementById('conf-back');
    if (backBtn) {
      if (historyStack.length > 1) {
        backBtn.classList.remove('hidden');
      } else {
        backBtn.classList.add('hidden');
      }
    }
  }

  function showEarlyExit() {
    document.querySelectorAll('.conf-step').forEach(el => el.classList.add('hidden'));
    document.getElementById('step-early-exit')?.classList.remove('hidden');
    document.getElementById('conf-progress-text')!.innerText = 'Coming Soon';
    document.getElementById('conf-progress-pct')!.innerText = '100%';
    document.getElementById('conf-progress-bar')!.style.width = '100%';
    document.getElementById('conf-back')?.classList.remove('hidden');
    historyStack.push(99); // dummy step id for early exit
  }

  function showResults() {
    document.querySelectorAll('.conf-step').forEach(el => el.classList.add('hidden'));
    document.getElementById('step-result')?.classList.remove('hidden');
    document.getElementById('conf-progress-text')!.innerText = 'Recommendation';
    document.getElementById('conf-progress-pct')!.innerText = '100%';
    document.getElementById('conf-progress-bar')!.style.width = '100%';
    document.getElementById('conf-back')?.classList.remove('hidden');
    historyStack.push(100); // dummy for result

    const resultList = document.getElementById('result-list');
    const resultSubtitle = document.getElementById('result-subtitle');
    const resultHint = document.getElementById('result-hint');
    if (!resultList || !resultSubtitle) return;
    
    let html = '';
    
    if (answers.duration === 'short') {
      resultSubtitle.innerText = "Based on your answers, you'll need very little — here's what applies:";
      if (resultHint) resultHint.classList.add('hidden');
    } else {
      resultSubtitle.innerText = "Based on your answers, here is exactly what applies to you:";
      if (resultHint) resultHint.classList.remove('hidden');
    }

    // 1. Visa
    if (answers.origin === 'noneu') {
      if (answers.duration === 'long') {
        html += createResultItem('Digital Nomad Visa', "You'll need a Digital Nomad Visa — apply 1–2 months before you move. We handle the full application.");
      } else {
        html += createResultItem('Visa requirements', "If you stay under 90 days you likely don't need a visa; between 90 days and 6 months you may need a short-stay visa — talk to us.");
      }
      // Insurance upsell
      html += createResultItem('Health Insurance', 'A private health insurance is required for your visa — we can sort that too.', false, true);
    }

    // 2. AFM & Registration
    if (answers.duration === 'long') {
      html += createResultItem('Tax Number & Registration', "You'll need a Greek tax number (AFM) and to register your activity — we set this up for you.");
    } else {
      html += createResultItem('No Registration needed', "You likely won't need to register or pay Greek tax — you stay below the tax-residency threshold.");
    }

    // 3. 5C
    if (answers.duration === 'long') {
      if (answers.income === 'high' || answers.income === 'highest') {
        html += createResultItem('50% Tax Break (5C)', 'Strongly recommended — the 5C regime exempts 50% of your Greek income from tax for 7 years. At your income this saves you several thousand euros per year. Apply by July 31.', true);
      } else if (answers.income === 'mid') {
        html += createResultItem('50% Tax Break (5C)', "Worth considering — 5C still gives meaningful savings. We'll calculate if it's worth it for you.", true);
      } else {
        html += createResultItem('50% Tax Break (5C)', 'Optional — savings are smaller at your income level, but still available.', false, true);
      }
    }

    // 4. Bookkeeping
    if (answers.duration === 'long') {
      if (answers.employment === 'freelance') {
        html += createResultItem('Full Bookkeeping', 'Recommended — monthly bookkeeping & tax compliance (myDATA, EFKA, VAT, year-end, and the mandatory e-invoicing from Oct 2026). We handle it all in English.', true);
      } else {
        html += createResultItem('Annual Tax Return', "You'll need an annual Greek tax return — we handle that for you.");
      }
    }

    resultList.innerHTML = html;
    
    const inputConfig = document.getElementById('contact-config-data') as HTMLInputElement;
    if (inputConfig) {
      inputConfig.value = JSON.stringify(answers);
    }

    window.dispatchEvent(new CustomEvent('taxomade:configurator-complete', { detail: answers }));
  }

  function createResultItem(title: string, desc: string, highlight = false, optional = false) {
    const bgClass = highlight ? 'bg-slate-100 border-slate-300' : 'bg-slate-50 border-slate-100';
    const iconColor = highlight ? 'text-blue-800' : 'text-slate-500';
    const tag = highlight ? '<span class="ml-2 text-xs font-bold text-blue-800 uppercase tracking-wider bg-white px-2 py-0.5 rounded border border-blue-200">Recommended</span>' : (optional ? '<span class="ml-2 text-xs font-medium text-slate-500 uppercase tracking-wider bg-white px-2 py-0.5 rounded border border-slate-200">Optional</span>' : '');
    
    return `
      <div class="p-4 rounded-xl border ${bgClass} flex items-start">
        <svg class="w-6 h-6 ${iconColor} flex-shrink-0 mt-0.5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <div>
          <h4 class="font-bold text-slate-900 flex items-center flex-wrap gap-y-1">${title}${tag}</h4>
          <p class="text-sm text-slate-600 mt-1 leading-relaxed">${desc}</p>
        </div>
      </div>
    `;
  }
</script>
