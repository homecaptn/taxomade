<header class="fixed top-4 left-4 right-4 md:left-1/2 md:-translate-x-1/2 md:w-full md:max-w-[calc(100%-2rem)] lg:max-w-7xl z-50 bg-white/50 backdrop-blur-2xl border border-slate-200/50 rounded-2xl shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 md:h-20">
      
      <!-- Logo (Left) -->
      <div class="flex-shrink-0 flex flex-col justify-center">
        <a href="/">
          <img src="/logo.svg" alt="taxomade Logo" class="h-8 w-auto" />
        </a>
        <span class="text-[10px] text-slate-500 font-bold mt-1 tracking-widest uppercase">The Tax Nomad Setup</span>
      </div>
      
      <!-- Right aligned section: Nav + CTA -->
      <div class="hidden md:flex items-center space-x-8 ml-auto">
        <nav class="flex items-center space-x-8">

          <a href="/greece/digital-nomad-visa" class="text-slate-600 hover:text-slate-900 font-medium transition-colors">Digital Nomad Visa</a>
          <a href="/greece/tax-number-afm" class="text-slate-600 hover:text-slate-900 font-medium transition-colors">Tax Number (AFM)</a>
          <a href="/greece/50-percent-tax-break" class="text-slate-600 hover:text-slate-900 font-medium transition-colors">50% Tax Break</a>
          <a href="/greece/ongoing-bookkeeping" class="text-slate-600 hover:text-slate-900 font-medium transition-colors">Bookkeeping</a>

        </nav>
        
        <a href="#configurator" class="inline-flex items-center justify-center pl-5 pr-3 py-2 text-sm font-bold rounded-lg text-white bg-slate-900 hover:bg-blue-800 transition-colors duration-200 group">
          <span class="mr-3">Talk to us</span>
          <div class="flex -space-x-1.5">
            <img class="inline-block h-6 w-6 rounded-full ring-2 ring-blue-800 group-hover:ring-blue-900 object-cover" src="https://randomuser.me/api/portraits/men/32.jpg" alt="Support Staff 1" />
            <img class="inline-block h-6 w-6 rounded-full ring-2 ring-blue-800 group-hover:ring-blue-900 object-cover" src="https://randomuser.me/api/portraits/women/44.jpg" alt="Support Staff 2" />
          </div>
        </a>
      </div>

    </div>
  </div>
</header>
