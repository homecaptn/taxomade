---
---
<section id="services" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Our Services</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Everything you need to relocate and work legally, without the headache.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      
      <!-- AFM -->
      <div class="bg-slate-50 p-8 rounded-3xl border border-slate-100 hover:border-slate-200 transition-colors">
        <div class="h-12 w-12 bg-white text-slate-900 rounded-2xl flex items-center justify-center mb-6 shadow-sm border border-slate-100">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-3">Tax Number (AFM)</h3>
        <p class="text-slate-600">We secure your local tax number—the foundation for renting, working, and banking.</p>
      </div>

      <!-- Visa -->
      <div class="bg-slate-50 p-8 rounded-3xl border border-slate-100 hover:border-slate-200 transition-colors">
        <div class="h-12 w-12 bg-white text-slate-900 rounded-2xl flex items-center justify-center mb-6 shadow-sm border border-slate-100">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-3">Digital Nomad Visa</h3>
        <p class="text-slate-600">Full end-to-end handling of your visa application for Non-EU citizens.</p>
      </div>

      <!-- 5C -->
      <div class="bg-slate-50 p-8 rounded-3xl border border-slate-100 hover:border-slate-200 transition-colors">
        <div class="h-12 w-12 bg-white text-slate-900 rounded-2xl flex items-center justify-center mb-6 shadow-sm border border-slate-100">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-3">50% Tax Break</h3>
        <p class="text-slate-600">We file the complex Article 5C application so you pay half the income tax for 7 years.</p>
      </div>

      <!-- Bookkeeping -->
      <div class="bg-slate-900 p-8 rounded-3xl shadow-xl transform md:-translate-y-2 relative border border-slate-800">
        <div class="absolute -top-3 right-6 bg-accent-400 text-slate-900 text-xs font-bold px-3 py-1 rounded-full">
          Core Focus
        </div>
        <div class="h-12 w-12 bg-slate-800 text-accent-400 rounded-2xl flex items-center justify-center mb-6 border border-slate-700">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-3">Ongoing Bookkeeping</h3>
        <p class="text-slate-400">Monthly accounting, electronic invoicing (mandatory 2026), VAT, and yearly tax returns fully managed.</p>
      </div>

    </div>
  </div>
</section>
