---
---
<section id="how-it-works" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">How it works</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">Your journey to Southern Europe, mapped out. We handle the bureaucracy so you can focus on your work.</p>
    </div>

    <!-- Timeline Container -->
    <div class="relative max-w-5xl mx-auto">
      <!-- Connecting Line -->
      <div class="hidden md:block absolute top-1/2 left-0 w-full h-1 bg-slate-100 -translate-y-1/2 z-0 rounded-full"></div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10">
        
        <!-- Step 1: Visa (Non-EU Only) -->
        <div id="timeline-step-visa" class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm transition-all duration-300 relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-slate-900 text-white text-xs font-bold px-3 py-1 rounded-full">
            Pre-arrival
          </div>
          <div class="h-12 w-12 bg-slate-50 text-slate-400 rounded-full flex items-center justify-center mx-auto mb-4 border border-slate-100">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 text-center mb-2">Digital Nomad Visa</h3>
          <p class="text-sm text-slate-600 text-center">Required only for Non-EU citizens. Apply 1-2 months before arrival.</p>
          <div id="timeline-eu-badge" class="hidden mt-3 text-center">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500">
              Skipped for EU citizens
            </span>
          </div>
        </div>

        <!-- Step 2: AFM -->
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brand-600 text-white text-xs font-bold px-3 py-1 rounded-full">
            Month 0
          </div>
          <div class="h-12 w-12 bg-brand-50 text-brand-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 text-center mb-2">Tax Number (AFM)</h3>
          <p class="text-sm text-slate-600 text-center">The foundation. Needed if you stay 6+ months and register locally.</p>
        </div>

        <!-- Step 3: 5C Tax Break -->
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brand-600 text-white text-xs font-bold px-3 py-1 rounded-full">
            Month 6+
          </div>
          <div class="h-12 w-12 bg-brand-50 text-brand-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 text-center mb-2">50% Tax Break (5C)</h3>
          <p class="text-sm text-slate-600 text-center">Save up to 50% on income tax once you become a tax resident.</p>
        </div>

        <!-- Step 4: Bookkeeping -->
        <div class="bg-slate-900 p-6 rounded-2xl shadow-xl transform md:scale-105 relative border border-slate-800">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-accent-400 text-slate-900 text-xs font-bold px-3 py-1 rounded-full">
            Ongoing
          </div>
          <div class="h-12 w-12 bg-slate-800 text-accent-400 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-white text-center mb-2">Monthly Bookkeeping</h3>
          <p class="text-sm text-slate-400 text-center">We handle your invoices, VAT, and annual tax returns completely.</p>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  // Listen for the configurator event to dim the Visa step for EU citizens
  window.addEventListener('taxomade:origin-change', (e: any) => {
    const isEu = e.detail === 'eu';
    const visaStep = document.getElementById('timeline-step-visa');
    const euBadge = document.getElementById('timeline-eu-badge');
    
    if (visaStep && euBadge) {
      if (isEu) {
        visaStep.classList.add('opacity-40', 'grayscale');
        euBadge.classList.remove('hidden');
      } else {
        visaStep.classList.remove('opacity-40', 'grayscale');
        euBadge.classList.add('hidden');
      }
    }
  });
</script>
