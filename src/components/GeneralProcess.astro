---
---
<section id="general-process" class="py-24 bg-white border-t border-slate-100 relative overflow-hidden">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-black text-slate-900 mb-4 tracking-tight">How it works, <span class="text-slate-400">how little you do.</span></h2>
      <p class="text-lg text-slate-600">Our goal is to keep your to-do list as short as possible.</p>
    </div>

    <div class="relative">
      <!-- Central Line -->
      <div class="hidden md:block absolute left-1/2 top-4 bottom-4 w-px bg-slate-200 -translate-x-1/2"></div>

      <!-- Step 1 -->
      <div class="relative flex flex-col md:flex-row items-center justify-between mb-16">
        <div class="md:w-[45%] mb-6 md:mb-0 md:text-right">
          <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-600 text-xs font-bold uppercase tracking-wider mb-3">
            Step 1: Your part
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Choose & submit</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Find what you need via our configurator or select a single service. Upload your documents securely.</p>
        </div>
        
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-white border-2 border-slate-300 text-slate-400 font-bold z-10 hidden md:flex">
          1
        </div>
        
        <div class="md:w-[45%] text-center md:text-left text-slate-500">
          <!-- Placeholder for visual balance -->
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative flex flex-col md:flex-row items-center justify-between mb-16 md:flex-row-reverse">
        <div class="md:w-[45%] mb-6 md:mb-0 md:text-left">
          <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold uppercase tracking-wider mb-3">
            Step 2: taxomade™
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">We align (Optional)</h3>
          <p class="text-slate-600 text-sm leading-relaxed">We review your request and get in touch if anything is missing or hop on a quick call to answer questions.</p>
        </div>
        
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-blue-800 text-white font-bold border-2 border-blue-800 z-10 hidden md:flex shadow-sm">
          2
        </div>
        
        <div class="md:w-[45%] text-center md:text-right text-slate-500">
        </div>
      </div>

      <!-- Step 3 -->
      <div class="relative flex flex-col md:flex-row items-center justify-between">
        <div class="md:w-[45%] mb-6 md:mb-0 md:text-right text-slate-500">
          <div class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-100 text-emerald-800 text-xs font-bold uppercase tracking-wider mb-3">
            Step 3: Your part
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Sit back and enjoy</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Focus on your life and work while we handle the bureaucracy in the background.</p>
        </div>
        
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-emerald-600 text-white font-bold border-2 border-emerald-600 z-10 hidden md:flex shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
        </div>
        
        <div class="md:w-[45%] text-center md:text-left">
          <div class="inline-flex items-center px-3 py-1 rounded-full bg-emerald-100 text-emerald-800 text-xs font-bold uppercase tracking-wider mb-3">
            Step 3: taxomade™
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">We do the work</h3>
          <p class="text-slate-600 text-sm leading-relaxed">We file the applications, talk to local authorities, and deliver the final results right to your inbox.</p>
        </div>
      </div>
    </div>

    <!-- Notice -->
    <div class="mt-20 max-w-2xl mx-auto bg-slate-50 border border-slate-200 rounded-2xl p-6 text-center">
      <p class="text-sm text-slate-600">
        <svg class="w-5 h-5 inline-block mr-1 -mt-0.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        The detailed process for each specific service can be found on the respective <a href="#how-it-works" class="font-bold text-slate-900 underline hover:text-blue-800">service pages</a>.
      </p>
    </div>

  </div>
</section>
